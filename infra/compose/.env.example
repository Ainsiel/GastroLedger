POSTGRES_DB=gastroledger
POSTGRES_USER=gastroledger
# Non-secret credential for the isolated localhost Compose contract only.
POSTGRES_PASSWORD=gastroledger-local-only
POSTGRES_RUNTIME_USER=gastroledger_runtime
# Separate non-secret localhost runtime credential; production injects its own value.
POSTGRES_RUNTIME_PASSWORD=gastroledger-runtime-local-only
POSTGRES_PORT=5432
API_PORT=8000
WEB_PORT=3000
